# =============================================================
#  Kanad S.H.I.E.L.D. — .gitignore
# =============================================================

# Secrets — NEVER commit
.env
*.key
*.pem
*.crt
!services/api-gateway/gen_certs.sh

# Node.js
node_modules/
npm-debug.log*
.npm/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ML models (large binary files — store in DVC or shared drive)
services/ai-engine/models/*.joblib
services/ai-engine/models/*.index
services/ai-engine/models/*.pkl

# Docker volumes
.docker/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
