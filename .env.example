# =============================================================
#  Kanad S.H.I.E.L.D. — Environment Variables Reference
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# =============================================================

# ── Postgres ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@postgres:5432/safetydb
POSTGRES_DB=safetydb
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ── SOS Service ──────────────────────────────────────────────
SOS_PORT=4000

# ── ERSS / 112 Integration ───────────────────────────────────
# Set to 'mock' for demo, 'live' when real credentials are available
ERSS_MODE=mock
ERSS_BASE_URL=https://erss.112.gov.in/api/v1
ERSS_API_KEY=

# ── Guardian Notifications ───────────────────────────────────
# Set to 'mock' (console log) or 'twilio'
NOTIFY_MODE=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO / S3 ───────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=evidence
MINIO_USE_SSL=false

# ── AI Engine (Dev 2) ────────────────────────────────────────
AI_ENGINE_URL=http://ai-engine:4002

# ── Neo4j (Dev 2 writes, Dev 1 reads via case_links table) ──
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Cybercrime Service ───────────────────────────────────────
CYBERCRIME_PORT=4001

# ── NTP ──────────────────────────────────────────────────────
NTP_SERVER=pool.ntp.org

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
